{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",

  "functions": {
    "app/api/cfo/extract/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "app/api/assistant/chat/route.ts": {
      "maxDuration": 30
    },
    "app/api/admin/stats/route.ts": {
      "maxDuration": 30
    },
    "app/api/vendors/apply/route.ts": {
      "maxDuration": 15
    },
    "app/api/vendors/admin/decide/route.ts": {
      "maxDuration": 15
    }
  },

  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.moomentum.events" }],
      "destination": "https://moomentum.events/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "momentum-psi-ten.vercel.app" }],
      "destination": "https://moomentum.events/:path*",
      "permanent": true
    }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
