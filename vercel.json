{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",

  "functions": {
    "app/api/cfo/extract/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "app/api/assistant/chat/route.ts": {
      "maxDuration": 30
    },
    "app/api/admin/stats/route.ts": {
      "maxDuration": 30
    },
    "app/api/vendors/apply/route.ts": {
      "maxDuration": 15
    },
    "app/api/vendors/admin/decide/route.ts": {
      "maxDuration": 15
    },
    "app/api/guests/voice-campaign/start/route.ts": {
      "maxDuration": 60
    },
    "app/api/webhooks/nlpearl/route.ts": {
      "maxDuration": 15
    },
    "app/api/webhooks/whatsapp/route.ts": {
      "maxDuration": 15
    },
    "app/api/whatsapp/send-rsvp/route.ts": {
      "maxDuration": 60
    },
    "app/api/whatsapp/send-seating/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/whatsapp-digest/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/whatsapp-voice-fallback/route.ts": {
      "maxDuration": 60
    },
    "app/api/send-scheduled/route.ts": {
      "maxDuration": 60
    }
  },

  "crons": [
    {
      "path": "/api/send-scheduled",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/whatsapp-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/whatsapp-voice-fallback",
      "schedule": "0 10 * * *"
    }
  ],

  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.moomentum.events" }],
      "destination": "https://moomentum.events/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "momentum-psi-ten.vercel.app" }],
      "destination": "https://moomentum.events/:path*",
      "permanent": true
    },
    { "source": "/alcohol",         "destination": "/budget",    "permanent": true },
    { "source": "/timeline",        "destination": "/dashboard", "permanent": true },
    { "source": "/checklist",       "destination": "/dashboard", "permanent": true },
    { "source": "/compare",         "destination": "/vendors",   "permanent": true },
    { "source": "/pricing",         "destination": "/#pricing",  "permanent": true },
    { "source": "/pass/:rest*",     "destination": "/dashboard", "permanent": true },
    { "source": "/calendar",        "destination": "/dashboard", "permanent": true },
    { "source": "/calendar/:rest*", "destination": "/dashboard", "permanent": true }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
